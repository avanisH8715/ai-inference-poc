[Unit]
Description=NeuralChat Inference Server
Documentation=https://github.com/phoenixunity2026/ai-inference-poc
After=network.target ollama.service
Requires=ollama.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/neuralchat

# Start the Python inference server
ExecStart=/opt/neuralchat-venv/bin/python3 /opt/neuralchat/inference_server.py

# Auto-restart on crash
Restart=always
RestartSec=5

# Give Ollama time to fully load models before health checks pass
TimeoutStartSec=180

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=neuralchat

# Security hardening
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
